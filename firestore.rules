rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── LISTINGS ─────────────────────────────────────────────────────────────
    match /listings/{listingId} {
      // Any authenticated user can browse listings
      allow read: if request.auth != null;
      // Only the donor can create a listing under their own UID
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.donorId;
      // Only the original donor can update or delete their listing
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.donorId;
    }

    // ─── USERS ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can view profiles (needed for donor info)
      allow read: if request.auth != null;
      // Each user can only write their own profile document
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── CONVERSATIONS ────────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      // Participants can read and write the conversation document
      allow read, write: if request.auth != null && (
        // Existing doc: verify caller is a participant
        (resource != null && request.auth.uid in resource.data.participantIds)
        // New doc: verify caller is in the participantIds being set
        || (resource == null && request.auth.uid in request.resource.data.participantIds)
      );

      // Messages subcollection — accessible only to conversation participants
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId))
               .data.participantIds;
      }
    }

    // ─── RATINGS ──────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      // Only the reviewer can submit a rating under their own UID
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.fromUserId;
    }
  }
}
